rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.email == "admin@auravilla.local";
    }

    match /property-images/{propertySlug}/{fileName} {
      allow read: if true;
      allow create, update, delete: if isAdmin()
        && request.resource.contentType.matches('image/.*');
    }
  }
}
