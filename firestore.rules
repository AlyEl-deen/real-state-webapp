rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.email == "admin@auravilla.local";
    }

    match /properties/{propertyId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /siteSettings/{documentId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow create: if signedIn() && request.auth.uid == userId;
      allow read, update: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /rentalRequests/{requestId} {
      allow create: if signedIn();
      allow read, update, delete: if isAdmin();
    }

    match /advisorRequests/{requestId} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAdmin();
    }
  }
}
